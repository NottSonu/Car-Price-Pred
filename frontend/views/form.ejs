<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Car Price Predictor</title>

    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #c22a2a, #d9ff03);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            backdrop-filter: blur(15px);
            background: rgba(0, 0, 0, 0.1);
            padding: 30px;
            border-radius: 20px;
            width: 400px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            color: white;
        }

        h2 {
            text-align: center;
            margin-bottom: 20px;
        }

        input, select {
            width: 100%;
            padding: 10px;
            margin: 8px 0;
            border: none;
            border-radius: 10px;
            outline: none;
        }

        input {
            background: rgba(0, 0, 0, 0.2);
            color: white;
        }

        select {
            background: white;
            color: black;
        }

        button {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 12px;
            background: #7e1bff;
            background: linear-gradient(to right, #46f4fa, #3afde3);
            color: white;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            transform: scale(1.05);
        }

        .result {
            margin-top: 20px;
            text-align: center;
            font-size: 18px;
            font-weight: bold;
            color: #00ffcc;
        }
    </style>
</head>

<body>

<div class="container">
    <h2>🚗 Car Price Predictor</h2>

    <form action="/predict" method="POST">
        <input type="text" name="present_price" placeholder="Present Price (in Lakhs)" required>
        <input type="text" name="kms_driven" placeholder="Kms Driven" required>
        <input type="text" name="owner" placeholder="Number of Owners" required>
        <input type="text" name="year" placeholder="Year of Purchase" required>

        <select name="fuel">
            <option value="">Fuel Type</option>
            <option>Petrol</option>
            <option>Diesel</option>
        </select>

        <select name="seller">
            <option value="">Seller Type</option>
            <option>Dealer</option>
            <option>Individual</option>
        </select>

        <select name="transmission">
            <option value="">Transmission</option>
            <option>Manual</option>
            <option>Automatic</option>
        </select>

        <button type="submit">Predict Price 🚀</button>
    </form>

    <% if (typeof prediction !== 'undefined') { %>
        <div class="result">
            Predicted Price: ₹ <%= prediction %> Lakhs
        </div>
    <% } %>
</div>

</body>
</html>